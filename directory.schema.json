{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "directory.schema.json",
  "title": "Registry Directory",
  "description": "Curated index of public shadcn-compatible registries.",
  "type": "object",
  "additionalProperties": false,
  "required": ["$schema", "registries"],
  "properties": {
    "$schema": {
      "type": "string",
      "const": "./directory.schema.json"
    },
    "registries": {
      "type": "array",
      "minItems": 1,
      "items": {
        "$ref": "#/$defs/directoryEntry"
      }
    }
  },
  "$defs": {
    "directoryEntry": {
      "type": "object",
      "additionalProperties": false,
      "required": ["source", "displayName", "description", "github"],
      "properties": {
        "source": {
          "type": "string",
          "pattern": "^[A-Za-z0-9_.-]+/[A-Za-z0-9_.-]+$"
        },
        "displayName": {
          "type": "string",
          "minLength": 1
        },
        "description": {
          "type": "string",
          "minLength": 1
        },
        "github": {
          "type": "string",
          "pattern": "^https://github\\.com/[A-Za-z0-9_.-]+/[A-Za-z0-9_.-]+$"
        },
        "homepage": {
          "type": "string",
          "format": "uri"
        },
        "logo": {
          "type": "string",
          "maxLength": 12000,
          "pattern": "^\\s*<svg[\\s>]"
        }
      }
    }
  }
}
